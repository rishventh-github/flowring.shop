# Copy to .env and set your own values
PORT=3000
ADMIN_PASSWORD=your-secret-admin-password
SESSION_SECRET=your-session-secret-string

# Optional: absolute path where SQLite lives (flowring.db). Default is ./data next to server.js.
# On Render, attach a disk with mount path `data` or set this to your mount path.
# DATA_DIR=/var/data
